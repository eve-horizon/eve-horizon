# Manual Test Secrets
# Copy this file to manual-tests.secrets and fill in your values
# Import with: eve secrets import --org org_manualtestorg --file manual-tests.secrets

# Required for job execution (LLM harness)
Z_AI_API_KEY=your-zai-api-key

# Required for private repo access
GITHUB_TOKEN=ghp_your-github-token

# Required for container registry (deploy scenarios)
GHCR_USERNAME=your-github-username
GHCR_TOKEN=ghp_your-ghcr-token
