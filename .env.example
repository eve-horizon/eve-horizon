# Eve Horizon Environment Configuration
#
# Ports are configured via: ./bin/eh configure
# See .eve-horizon.yaml (gitignored, per-developer)
#
# Secrets/config can live in .env (copy this file to .env).
# OAuth tokens and API keys go in system-secrets.env.local:
#   ./bin/eh auth extract --save   # Extracts Claude/Codex OAuth tokens
#
# Both .env and system-secrets.env.local are gitignored.
# Default dev works without these unless you need private repo access or API keys.

# Database (these are the defaults - override as needed)
EVE_DB_USER=eve
EVE_DB_PASSWORD=eve
EVE_DB_NAME=eve
EVE_DB_NAME_TEST=eve_test

# Auth (optional)
# Set to true for hosted stacks; leave false for local dev.
EVE_AUTH_ENABLED=false
# Supabase JWT secret used to validate tokens when auth is enabled.
# EVE_AUTH_JWT_SECRET=your-supabase-jwt-secret

# Worker
EVE_CLEANUP_WORKSPACE_ON_SUCCESS=true
EVE_CLEANUP_WORKSPACE_ON_FAILURE=true

# Secrets (optional)
# EVE_SECRETS_MASTER_KEY=replace-me
# EVE_INTERNAL_API_KEY=replace-me

# Claude / mclaude auth (choose one)
# Option 1: API key (preferred)
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option 2: OAuth via Claude Code (saved to system-secrets.env.local)
# ./bin/eh auth extract --save
#
# Model override
# CLAUDE_MODEL=opus

# Z.ai (zai harness)
# Z_AI_API_KEY=...
# ZAI_MODEL=glm-5

# Transparent protocol bridge (optional; required for anthropic->openai mismatch routing)
# EVE_BRIDGE_LITELLM_ANTHROPIC_OPENAI_URL=http://litellm:4000
# EVE_BRIDGE_LITELLM_ANTHROPIC_OPENAI_KEY=bridge-gateway-key

# Platform Ollama (optional; set to auto-bootstrap a platform-scoped ollama_pool target)
# EVE_OLLAMA_BASE_URL=http://10.0.x.x:11434
# EVE_INFERENCE_HEALTH_PROBE_ENABLED=true
# On-demand GPU wake (set ASG name to auto-start GPU on first inference request)
# EVE_OLLAMA_ASG_NAME=eve-ollama-asg
# EVE_OLLAMA_WAKE_ENABLED=true
