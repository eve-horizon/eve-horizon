#!/usr/bin/env bash
set -euo pipefail

# Stub harness for e2e testing - outputs expected marker
# Real harness uses OpenSkills synced to agent config directory

harness="mclaude"
timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

echo "{\"type\":\"event\",\"timestamp\":\"$timestamp\",\"content\":{\"message\":\"skill-pack-check core_pack=e2e-core repo_pack=e2e-repo\",\"harness\":\"$harness\"}}"

# Emit a couple of assistant messages with usage blocks so eve-agent-cli can
# derive `llm.call` events in stub mode.
echo "{\"type\":\"assistant\",\"model\":\"claude-opus-4-5-20250929\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"Hello from stub mclaude (call 1)\"}],\"usage\":{\"input_tokens\":1200,\"output_tokens\":340,\"cache_read_tokens\":0,\"cache_write_tokens\":0,\"reasoning_tokens\":0}}}"
echo "{\"type\":\"llm.call\",\"ts\":\"$timestamp\",\"provider\":\"anthropic\",\"model\":\"claude-opus-4-5-20250929\",\"source\":\"byok\",\"status\":\"error\",\"latency_ms\":250,\"usage\":{\"input_tokens\":0,\"output_tokens\":0,\"cache_read_tokens\":0,\"cache_write_tokens\":0,\"reasoning_tokens\":0}}"
echo "{\"type\":\"assistant\",\"model\":\"claude-opus-4-5-20250929\",\"message\":{\"content\":[{\"type\":\"text\",\"text\":\"Hello from stub mclaude (call 2)\"}],\"usage\":{\"input_tokens\":1800,\"output_tokens\":520,\"cache_read_tokens\":0,\"cache_write_tokens\":0,\"reasoning_tokens\":0}}}"
