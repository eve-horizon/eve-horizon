#!/usr/bin/env bash
# Shell-sourced test env for pnpm -r test
# Respects ./bin/eh configure (base_port) via _config.sh
#
# NOTE: All values below are TEST-ONLY fixtures — dummy keys and a throwaway
# test keypair. They are not real secrets. Secret scanners are configured to
# allowlist this file (see .gitleaks.toml).

ENV_TEST_SOURCE=""
if [[ -n "${BASH_SOURCE[0]:-}" ]]; then
  ENV_TEST_SOURCE="${BASH_SOURCE[0]}"
elif [[ -n "${ZSH_VERSION:-}" ]]; then
  ENV_TEST_SOURCE="${(%):-%N}"
else
  ENV_TEST_SOURCE="$0"
fi

if [[ -n "$ENV_TEST_SOURCE" && -f "$ENV_TEST_SOURCE" ]]; then
  TEST_ENV_DIR="$(cd "$(dirname "$ENV_TEST_SOURCE")" && pwd)"
else
  TEST_ENV_DIR="$(pwd)"
fi

source "$TEST_ENV_DIR/bin/eh-commands/_config.sh"

EVE_API_URL="http://localhost:${EVE_API_PORT}"
EVE_DB_PORT="${EVE_DB_PORT}"
EVE_DB_NAME_TEST="${EVE_DB_NAME_TEST}"
NODE_ENV="test"

# Fixed test keys
EVE_SECRETS_MASTER_KEY="test-master-key"
EVE_INTERNAL_API_KEY="test-internal-key"
EVE_AUTH_ENABLED="true"
SUPABASE_JWT_SECRET="test-supabase-jwt-secret"
EVE_BOOTSTRAP_TOKEN="test-bootstrap-token"
EVE_AUTH_TEST_EMAIL="admin@example.com"
EVE_AUTH_TEST_PUBLIC_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAICFbuITNZ04OZRpanXt2i878l3YmqTyegR+OGW0IbR+T"
EVE_GITHUB_WEBHOOK_SECRET="test-github-webhook-secret"
# Bump orchestrator concurrency for parallel integration tests (default 4 starves under 48+ concurrent test jobs)
ORCH_CONCURRENCY=8
ORCH_TUNER_ENABLED="false"
