{
  "name": "@eve-horizon/chat",
  "version": "0.0.1",
  "description": "Browser and server client for Eve embedded app conversations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eve-horizon/eve-horizon.git",
    "directory": "packages/chat"
  },
  "keywords": ["eve", "chat", "conversations", "sse", "agents"],
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
